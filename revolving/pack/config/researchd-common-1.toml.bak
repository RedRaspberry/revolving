#The length of the researchPack queue
# Default: 7
# Range: 1 ~ 99
research_queue_length = 7
#Whether to use FTB Teams' API for team logic instead of Researchd's own.
#This disables the team screen and team command
use_ftb_teams = false
#Whether to load the examples resourcepack that can be enabled in the world creation screen.
load_examples_datapack = true

[debug]
	#Whether to enable console debug messages for Researchd
	console_debug = false
