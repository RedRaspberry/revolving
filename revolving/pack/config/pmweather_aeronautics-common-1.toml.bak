#Minimum PMWeather wind-vector magnitude before effects are applied. PMWeather's own units are used.
# Default: 35.0
# Range: 0.0 ~ 300.0
windThreshold = 35.0
#Inject PMWeather wind into Sable lift/drag calculations so wings see relative airflow.
enableAirflowLift = true
#How much PMWeather wind is treated as aerodynamic airflow for Sable lift providers. 1.0 = full sampled wind.
# Default: 1.0
# Range: 0.0 ~ 10.0
airflowInfluence = 1.0
#Also push the whole Sable sub-level center of mass. Disable for pure lift/drag integration.
enableBodyPush = true
#Whole-body wind push multiplier. Only used when enableBodyPush is true.
# Default: 0.025
# Range: 0.0 ~ 10.0
windInfluence = 0.025
#How strongly mass dampens wind. 1.0 = linear, 0.5 = square-root curve.
# Default: 0.65
# Range: 0.0 ~ 1.0
massScaling = 0.65
#Safety cap on the linear impulse applied to a sub-level during each Sable physics substep.
# Default: 60.0
# Range: 0.0 ~ 100000.0
maxImpulsePerSubstep = 60.0
#Random angular impulse multiplier in high wind. 0 disables turbulence torque.
# Default: 0.008
# Range: 0.0 ~ 10.0
turbulenceMultiplier = 0.008
#Allow ProtoManly's Weather tornado/suction effects in the sampled wind vector.
enableTornadoSuction = true
#Log sampled wind and impulses occasionally. Very noisy when enabled.
debugLogging = false
