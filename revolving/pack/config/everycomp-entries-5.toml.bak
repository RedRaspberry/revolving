#Disables certain types. Note that all these configs, like in any other mod, only hide stuff from tabs and disable their recipes
[types]

		[types.wood_type.createdieselgenerators]
			chip_wood = true

		[types.wood_type.would]
			willow = true
			baobab = true
			ebony = true
			fir = true
			pine = true
			cedar = true
			mahogany = true
			azalea = true
			palm = true
			maple = true
			aspen = true
			walnut = true
			blue_spruce = true

		[types.wood_type.pmweather]
			rotted = true
			charred = true
			smoldering = true

		[types.wood_type.dimdoors]
			driftwood = true

		[types.wood_type.caverns_and_chasms]
			azalea = true

		[types.wood_type.natures_spirit]
			redwood = true
			sugi = true
			wisteria = true
			fir = true
			willow = true
			aspen = true
			maple = true
			cypress = true
			olive = true
			joshua = true
			ghaf = true
			palo_verde = true
			coconut = true
			cedar = true
			larch = true
			mahogany = true
			saxaul = true

		[types.wood_type.minecraft]
			pale_oak = true

		[types.wood_type.createpolymer]
			rubber = true

		[types.leaves_type.would]
			willow = true
			baobab = true
			ebony = true
			fir = true
			pine = true
			cedar = true
			mahogany = true
			palm = true
			maple = true
			aspen = true
			walnut = true
			blue_spruce = true

		[types.leaves_type.dimdoors]
			driftwood = true

		[types.leaves_type.natures_spirit]
			frosty_redwood = true
			redwood = true
			sugi = true
			wisteria = true
			white_wisteria = true
			part_white_wisteria = true
			blue_wisteria = true
			part_blue_wisteria = true
			pink_wisteria = true
			part_pink_wisteria = true
			purple_wisteria = true
			part_purple_wisteria = true
			frosty_fir = true
			fir = true
			willow = true
			aspen = true
			yellow_aspen = true
			red_maple = true
			orange_maple = true
			yellow_maple = true
			cypress = true
			olive = true
			joshua = true
			ghaf = true
			palo_verde = true
			coconut = true
			cedar = true
			larch = true
			mahogany = true
			saxaul = true

		[types.leaves_type.minecraft]
			pale_oak = true

		[types.leaves_type.createpolymer]
			rubber = true

		[types.cake.createaddition]
			chocolate_cake = true
			honey_cake = true

		[types.cake.natures_spirit]
			cheese_block = true

#Disables specific entries
[entries]

		[entries.wood_type.create]
			window_pane = true
			window = true

		[entries.wood_type.shutterup]
			shutter = true

		[entries.wood_type.tradeworks]
			metal_shelf = true
			shelf = true
			side_shelf = true
