#Disables certain types. Note that all these configs, like in any other mod, only hide stuff from tabs and disable their recipes
[types]

		[types.wood_type.createdieselgenerators]
			chip_wood = true

		[types.wood_type.would]
			willow = true
			baobab = true
			ebony = true
			fir = true
			pine = true
			cedar = true
			mahogany = true
			azalea = true
			palm = true
			maple = true
			aspen = true
			walnut = true
			blue_spruce = true

		[types.wood_type.pmweather]
			rotted = true
			charred = true
			smoldering = true

		[types.wood_type.dimdoors]
			driftwood = true

		[types.wood_type.caverns_and_chasms]
			azalea = true

		[types.wood_type.minecraft]
			pale_oak = true

		[types.wood_type.createpolymer]
			rubber = true

		[types.leaves_type.would]
			willow = true
			baobab = true
			ebony = true
			fir = true
			pine = true
			cedar = true
			mahogany = true
			palm = true
			maple = true
			aspen = true
			walnut = true
			blue_spruce = true

		[types.leaves_type.dimdoors]
			driftwood = true

		[types.leaves_type.minecraft]
			pale_oak = true

		[types.leaves_type.createpolymer]
			rubber = true

		[types.cake.createaddition]
			chocolate_cake = true
			honey_cake = true

		[types.lantern.caverns_and_chasms]
			cupric_lantern = true
			copper_lantern = true
			exposed_copper_lantern = true
			weathered_copper_lantern = true
			oxidized_copper_lantern = true
			waxed_copper_lantern = true
			waxed_exposed_copper_lantern = true
			waxed_weathered_copper_lantern = true
			waxed_oxidized_copper_lantern = true

#Disables specific entries
[entries]

		[entries.wood_type.create]
			window_pane = true
			window = true

		[entries.wood_type.shutterup]
			shutter = true

		[entries.wood_type.tradeworks]
			metal_shelf = true
			shelf = true
			side_shelf = true
