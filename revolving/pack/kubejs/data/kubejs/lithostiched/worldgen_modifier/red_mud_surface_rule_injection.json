{
  "type": "lithostitched:add_surface_rule",
  "levels": [
    "minecraft:overworld"
  ],
  "surface_rule": {
    "type": "minecraft:condition",
    "if_true": {
      "type": "minecraft:noise_threshold",
      "noise": "minecraft:surface",
      "min_threshold": -64,
      "max_threshold": -0.55
    },
    "then_run": {
      "type": "minecraft:block",
      "result_state": {
        "Name": "minecraft:deepslate",
        "Properties": {
          "axis": "y"
        }
      }
    }
  }
}